---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/ui/Sidebar.astro';
import Footer from '../components/ui/Footer.astro';

const tags = [
  'Backend Development',
  'API Design',
  'System Database Management',
  'Authentication',
  'Problem Solving',
  'Debugging',
  'Vibe Coding',
];

const books = [
  {
    title: 'New Morning Mercies',
    author: 'Paul David Tripp',
    image: '/books/new-morning-mercies.jpg',
  },
  {
    title: 'Leonardo da Vinci',
    author: 'Walter Isaacson',
    image: '/books/leonardo-cover.jpg',
  },
  {
    title: 'Sentient Design',
    author: 'Josh Clark & Veronika Kindred',
    image: '/books/sentient-design-cover.jpg',
  },
];
---

<Layout
  title="About | Mirazul Haq Srabon"
  description="Backend developer focused on scalable systems and clean architecture."
>
  <Sidebar currentPath={Astro.url.pathname} />

  <div class="content-area pt-14 md:pt-0">
    <main>

      <!-- About -->
      <section>
        <h1>Backend Developer. Problem Solver.</h1>

        <p>
          I'm a developer focused on backend systems, APIs, and building scalable applications.
        </p>

        <!-- Tags -->
        <div>
          {tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      </section>

      <!-- Books -->
      <section>
        <h2>Currently Reading</h2>

        <div>
          {books.map((book) => (
            <div>
              <img src={book.image} alt={book.title} />
              <p>{book.title}</p>
              <p>{book.author}</p>
            </div>
          ))}
        </div>
      </section>

    </main>

    <Footer />
  </div>
</Layout>
